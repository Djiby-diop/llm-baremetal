# repl.cfg.example - Optional REPL defaults
# Copy this file to repl.cfg and adjust values for your hardware.
# The build script will auto-include repl.cfg in the boot image if present.

# Sampling parameters
temperature=0.75        # 0.0=greedy, 1.0=creative
min_p=0.05              # Min probability threshold (0.0-1.0)
top_p=0.95              # Nucleus sampling (0.0-1.0)
top_k=80                # Top-k sampling (0=off, typical 40-200)

repeat_penalty=1.15     # Repetition penalty (1.0=none, 1.5=strong)
no_repeat_ngram=4       # No-repeat ngram (0=off, typical 3-6)
max_tokens=160          # Max generation tokens (1-256)

# UI/output settings
stats=1                 # Print generation stats (0=off, 1=on)
stop_you=1              # Stop on \nYou: pattern (0=off, 1=on)
stop_nl=0               # Stop on double newline (0=off, 1=on)

# Boot splash settings
# Duration the splash image stays visible at boot (milliseconds).
# 0 disables the pause; max 10000.
splash_ms=5000

# Performance/diagnostics
attn=auto               # Attention SIMD (auto|sse2|avx2)
strict_budget=0         # Hard-stop on budget overrun (0=log only, 1=trip sentinel)

# Q8_0 blob perf option
# When using GGUF Q8_0 blob weights, you can optionally quantize activations too.
# This is faster on real AVX2 hardware, but adds extra approximation.
q8_act_quant=0          # 0=off, 1=all matmuls, 2=FFN-only (w1/w3/w2)

# Autorun (disabled by default)
# If you want to auto-run a script at boot, set this and provide llmk-autorun.txt on the boot volume.
# autorun_autostart=1

# Optional autorun behavior
# autorun_file=llmk-autorun.txt
# autorun_shutdown_when_done=0

# Snapshot auto-resume (disabled by default)
# Attempts to load a KV snapshot at boot so you can resume a conversation quickly.
# snap_autoload=1
# snap_file=llmk-snap.bin

# Cycle budgets (tune per machine; higher = more tolerance, lower = earlier overrun detect)
# Start conservative and adjust based on /ctx overrun counts.
budget_prefill=80000000000
budget_decode=60000000000

# Optional: set RNG seed for reproducible generation
# seed=42

# OO (Operating Organism) prototypes (disabled by default)
# Enables a tiny persistent state + journal on the boot volume.
# oo_enable=1
# Optional: allow the model to suggest system adaptations (requires a loaded model)
# oo_llm_consult=1
# Optional: enable multi-action parsing when consulting
# oo_multi_actions=1
# Optional: confidence gate for auto-apply (0=off, 1=enforced)
# oo_conf_gate=0
# oo_conf_threshold=60

# OO engines (stubs) - optional modes (0..2)
# These are intentionally OFF by default. Enable only what you want to test.
# Effective values can be inspected at runtime with /oo_status.
# evolvion_mode=0      # 0=off, 1=learn, 2=live
# synaption_mode=0     # 0=off, 1=track, 2=pin
# conscience_mode=0    # 0=off, 1=watch, 2=act
# neuralfs_mode=0      # 0=off, 1=index, 2=query
# ghost_mode=0         # 0=off, 1=send, 2=recv
# immunion_mode=0      # 0=off, 1=record, 2=act
# dreamion_mode=0      # 0=off, 1=light, 2=deep
# symbion_mode=0       # 0=off, 1=watch, 2=adapt
# collectivion_mode=0  # 0=off, 1=passive, 2=active
# metabion_mode=0      # 0=off, 1=track, 2=guide
# morphion_mode=0      # 0=off, 1=probe, 2=morph
# pheromion_mode=0     # 0=off, 1=trace, 2=boost
